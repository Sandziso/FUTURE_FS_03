# Build / distribution directories
/dist/
/build/
/out/

# Project specific (adjust as needed)
# Ignore any backup SQL dumps
*.sql
*.sql.gz
*.sql.zip

# Ignore any local overrides
*.local
local.*

# Ignore files that might contain sensitive info
*.key
*.pem
*.crt
*.p12

